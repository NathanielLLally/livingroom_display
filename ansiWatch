#

printf "\033[2j"
#eval "display_$cb_func"
#cat $display_file

# begin event loop
#
while true; do
     step=0

     # Get the current time in seconds since the epoch
     current_time=$(date +%s)

     # Calculate the elapsed time
     elapsed_time=$((current_time - start_time))
     elapsed_time_update=$((current_time - update_time))

     #  read keyboard input
