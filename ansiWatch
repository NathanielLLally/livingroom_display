function display_weather() {
	#smallest possible terminal console font
	#setfont Uni1-VGA8
	setfont Uni1-VGA16
}

function weather() {
	term_width=240
	local OUTFILE="$1"
	local output=$("/home/nathaniel/bin/weather_today.py")
	echo "$output" > /tmp/ansiWatchWeather.$USER

	     # use tput cols after setfont
	     term_width=240
	     local IFS=$'\n'  # Set internal field separator to newline

		echo "___" | toilet -f $FONTSPACE >> $OUTFILE
	     for line in $output; do
		 # Split the line into fields
		 local name=" "$(echo "$line" | cut -f1)" "
		 local temp=$(echo "$line" | cut -f2)
		 local wind=" "$(echo "$line" | cut -f3)
		 local short=$(echo "$line" | cut -f4)
		 local long=$(echo "$line" | cut -f5)


		 # Print field1 using the current font from fonts1
		 echo -e "${CYAN}$(toilet -w $term_width -f ${FONT_H1[index1]} <<< $name)${NC}" > $OUTFILE.1

		 # Print field2 using the current font from fonts2
		 echo -e "${WHITE}$(toilet -s -w $term_width -f ${FONT_H2[index2]} <<< $temp)${NC}" > $OUTFILE.2

		#

		 echo -e "${BLUE}$(toilet -s -w $term_width -f ${FONT_H2[index2]} <<< $wind)${NC}" > $OUTFILE.3


	#  pad the above files to all be same line count
	#
	lines1=$(wc -l < "$OUTFILE.1")
	lines2=$(wc -l < "$OUTFILE.2")
	lines3=$(wc -l < "$OUTFILE.3")
	max=$((lines1 > lines2 ? lines1 : lines2))
	max=$((max > lines3 ? max : lines3))
	pad1=$((max - lines1))
	pad2=$((max - lines2))
	pad3=$((max - lines3))
	pad_file() {
		local file=$1
		local padding=$2
		local top=$(( padding / 2 ))
		local bottom=$(( padding / 2 ))
		if (( (top + bottom) < padding )); then
			bottom=$(( bottom + 1 ))
		fi
		local output="${file}.padded"
		{
			for ((i=0; i<top; i++)); do
				echo ""
			done
			cat "$file"
			for ((i=0; i<bottom; i++)); do
				echo ""
			done
		} > "$output"
	}
	pad_file "$OUTFILE.1" $pad1
	pad_file "$OUTFILE.2" $pad2
	pad_file "$OUTFILE.3" $pad3

	  # Apply colors and combine horizontally
	  while IFS= read -r line1 <&3 && IFS= read -r line2 <&4 && IFS= read -r line3 <&5; do
	    printf "${CYAN}%s${NC}${GREEN}%s${NC}${BLUE}%s${NC}\n" "$line1" "$line2" "$line3" >> $OUTFILE
	  done 3<"$OUTFILE.1.padded" 4<"$OUTFILE.2.padded" 5<"$OUTFILE.3.padded"

		#echo "___" | toilet -w $term_width -f $FONTSPACE >> $OUTFILE

		 toilet -cs -w $term_width -f "${FONT_H3[index3]}" <<< "$short" >> $OUTFILE

		echo "___" | toilet -w $term_width -f $FONTSPACE >> $OUTFILE
	     done
	}

	function gcal48() {
		local OUTFILE="$1"
		EV=$("/home/nathaniel/bin/gcal48")
		echo "$EV" >> $OUTFILE
	}


